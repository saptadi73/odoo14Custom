<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <record id="form_simpanan_tree" model="ir.ui.view">
            <field name="name">form.simpanan.tree</field>
            <field name="model">form.simpanan</field>
            <field name="arch" type="xml">
                <tree string="Simpanan">
                    <field name="ref"/>
                    <field name="member_id" />
                    <field name="partner_id" />
                    <field name="product_id" />
                    <field name="balance"/>
                </tree>
            </field>
        </record>

        <record id="form_simpanan_form" model="ir.ui.view">
            <field name="name">form.simpanan.form</field>
            <field name="model">form.simpanan</field>
            <field name="arch" type="xml">
                <form string="Simpanan">
		<header>
                  <button name="func_submit" string="Submit" type="object" class="oe_highlight" states="draft" tracking="True"/>
                  <button name="func_approve" string="Active" type="object" class="oe_highlight" states="submit" tracking="True"/>
                  <button name="func_close" string="Closed" type="object" class="oe_highlight" states="approve" tracking="True"/>
                  <field name="state" widget="statusbar" statusbar_visible="draft,submit,approve,active,close" tracking="True"/>
		</header>
		<sheet>
		    <div class="oe_title">
                	<label for="ref"/>
                	<h1>
                    		<field name="ref" attrs="{'readonly': [('state', '=', 'active')]}" />
                	</h1>
            	    </div>
		<group>
			<group>
					<field name="member_id" attrs="{'readonly': [('state', '=', 'active')]}" />
                    <field name="partner_id" attrs="{'readonly': [('state', '=', 'active')]}" />
                    <field name="product_id" attrs="{'readonly': [('state', '=', 'active')]}" />
			</group>
            <group>
                    <field name="balance"/>
                    <field name="max_debit"/>
            </group>
		</group>
            <notebook>
                <page string="Simpanan" >
                    <group>
                        <field name="simpanan_line_ids" nolabel="1" options="{'reload_on_button': True}">
                            <tree edit="true" editable="bottom" create="true" delete="true">
                                <field name="tgl_simpanan" />
                                <field name="debit"/>
                                <field name="credit"/>
                                <field name="keterangan"/>
                                <field name="balance"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </notebook>
		</sheet>
					<div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

	<record id="form_simpanan_action" model="ir.actions.act_window">
            <field name="name">Simpanan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">form.simpanan</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create SimPin Syariah simpanan
              </p>
            </field>
        </record>

   	<menuitem id="form_simpanan" parent="simpin_syariah_simpanan_menu"
		name="Simpanan" sequence='1' action="form_simpanan_action"
 		groups="asa_simpin_syariah.group_simpin_syariah_user"/>
	</data>
</odoo>

