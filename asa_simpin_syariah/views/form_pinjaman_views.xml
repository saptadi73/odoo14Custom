<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <record id="form_pinjaman_tree" model="ir.ui.view">
            <field name="name">form.pinjaman.tree</field>
            <field name="model">form.pinjaman</field>
            <field name="arch" type="xml">
                <tree string="Pinjaman">
                    <field name="ref"/>
                    <field name="member_id" />
                    <field name="nama_pinjaman" />
                    <field name="tgl_pinjaman" />
                    <field name="nilai_pinjaman" />
                    <field name="angsuran"/>
                    <field name="periode_angsuran"/>
                    <field name="state" />
                </tree>
            </field>
        </record>

        <record id="form_pinjaman_form" model="ir.ui.view">
            <field name="name">form.pinjaman.form</field>
            <field name="model">form.pinjaman</field>
            <field name="arch" type="xml">
                <form string="Pembiayaan Tunai Syariah">
		<header>
                  <button name="func_submit" string="Submit" type="object" class="oe_highlight" states="draft" tracking="True"/>
                  <button name="func_approve" string="Approved" type="object" class="oe_highlight" states="submit" tracking="True"/>
                  <button name="func_close" string="Closed" type="object" class="oe_highlight" states="approve" tracking="True"/>
                  <field name="state" widget="statusbar" statusbar_visible="draft,submit,approve,close" tracking="True"/>
		</header>
		<sheet>
		    <div class="oe_title">
                	<label for="ref"/>
                	<h1>
                    		<field name="ref"/>
                	</h1>
            	    </div>
		<group>
			<group>
					<field name="member_id" />
					<field name="partner_id" />
                    <field name="nama_pinjaman" />
			</group>
				<group>
					<field name="tgl_pinjaman" />
                    <field name="nilai_pinjaman" />
                    <field name="periode_angsuran"/>
                    <field name="angsuran"/>
			</group>
		</group>
		<group>
                	    <field name="notes" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
		</group>
		</sheet>
					<div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

	<record id="form_pinjaman_action" model="ir.actions.act_window">
            <field name="name">Pinjaman</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">form.pinjaman</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create SimPin Syariah Pinjaman
              </p>
            </field>
        </record>

   	<menuitem id="form_pinjaman" parent="simpin_syariah_simpanan_menu"
		name="Pinjaman" sequence='2' action="form_pinjaman_action"
 		groups="asa_simpin_syariah.group_simpin_syariah_user"/>
	</data>
</odoo>

