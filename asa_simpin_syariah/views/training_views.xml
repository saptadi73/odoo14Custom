<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_training_tree" model="ir.ui.view">
            <field name="name">training.tree</field>
            <field name="model">training</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Training">
                    <field name="program_name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="responsible"/>
                </tree>
            </field>
        </record>
        <record id="view_training_form" model="ir.ui.view">
            <field name="name">training.view</field>
            <field name="model">training</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Training">
                    <sheet>
                        <group col="4">
                            <field name="program_name"/>
                            <label for="date_from" string="Time Period"/>
                            <div><field name="date_from" class="oe_inline"/> to <field name="date_to" class="oe_inline"/></div>
                            <field name="responsible"/>
                        </group>
                        <notebook colspan="4">
                            <page name="training_line" string="Anggota Details">
                                <field name="training_line_ids" nolabel="1" options="{'reload_on_button': True}">
                                    <tree edit="true" editable="bottom" create="true" delete="true">
                                        <field name="anggota_id"/>
                                        <field name="kode_anggota"/>
                                        <field name="jabatan_id"/>
                                        <field name="ceklis"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_training_search" model="ir.ui.view">
            <field name="name">training.search</field>
            <field name="model">training</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Training">
                    <field name="program_name"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Nama Program" name="group_by_program_name"
                                domain="[]" context="{'group_by':'program_name'}"/>
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_training_view">
            <field name="name">Training</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">training</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_training_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_training_view_form">
            <field name="act_window_id" ref="act_training_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_training_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_training_view_tree">
            <field name="act_window_id" ref="act_training_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_training_tree"/>
        </record>

        <menuitem id="menu_training_details"
                    name="Training"
                    parent="simpin_syariah_menu"
                    sequence="3"
                    action="act_training_view"/>

    </data>
</odoo>