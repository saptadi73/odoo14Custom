<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="res_partner_inherit" model="ir.ui.view">
            <field name="name">res.partner.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form" />
