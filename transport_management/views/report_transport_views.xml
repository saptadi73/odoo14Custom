<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="report_transport_tree" model="ir.ui.view">
            <field name="name">report.transport.tree</field>
            <field name="model">report.transport</field>
            <field name="arch" type="xml">
                <tree string="Report Transport">
                    <field name="responsible"/>
                    <field name="product_id"/>
                    <field name="partner_id"/>
                    <field name="no_do"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="route_id"/>
                    <field name="source_location_id"/>
                    <field name="destination_location_id"/>
                    <field name="rate_per_km"/>
                    <field name="distance"/>
                    <field name="total_cost"/>
                    <field name="shipment_date"/>
                </tree>
            </field>
        </record>

    <record model="ir.actions.act_window" id="act_report_transport_view">
            <field name="name">Report Transport</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">report.transport</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">

                </p>
            </field>
        </record>

    <menuitem id="menu_report_transport_details"
                    name="Report Transport"
                    parent="menu_report_transport"
                    sequence="1"
                    action="act_report_transport_view"/>
</odoo>