<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_business_category_tree" model="ir.ui.view">
        <field name="name">crm.business.category.tree</field>
        <field name="model">crm.business.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_crm_business_category_form" model="ir.ui.view">
        <field name="name">crm.business.category.form</field>
        <field name="model">crm.business.category</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_seed_categories_to_companies" type="object" string="Sync To Companies" class="oe_highlight"/>
                    <button name="action_cleanup_legacy_business_category_data" type="object" string="Cleanup Legacy Data"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Accounting">
                        <field name="analytic_account_id" domain="[('company_id', '=', company_id)]"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_business_category" model="ir.actions.act_window">
        <field name="name">Business Categories</field>
        <field name="res_model">crm.business.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_crm_business_category"
              name="Business Categories"
              parent="base.menu_administration"
              action="action_crm_business_category"
              sequence="85"
              groups="base.group_system"/>

    <record id="action_sync_seed_categories_to_companies_server" model="ir.actions.server">
        <field name="name">Sync Business Categories To Companies</field>
        <field name="model_id" ref="model_crm_business_category"/>
        <field name="binding_model_id" ref="model_crm_business_category"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">env['crm.business.category'].action_sync_seed_categories_to_companies()</field>
    </record>

    <record id="action_cleanup_legacy_business_category_data_server" model="ir.actions.server">
        <field name="name">Cleanup Legacy Business Category Data</field>
        <field name="model_id" ref="model_crm_business_category"/>
        <field name="binding_model_id" ref="model_crm_business_category"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">env['crm.business.category'].action_cleanup_legacy_business_category_data()</field>
    </record>
</odoo>
