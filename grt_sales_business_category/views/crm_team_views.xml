<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_team_form_sales_leader" model="ir.ui.view">
        <field name="name">crm.team.form.sales.leader</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="sale_team_leader_id" options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
