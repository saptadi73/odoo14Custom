<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_team_tree" model="ir.ui.view">
        <field name="name">kpi.team.tree</field>
        <field name="model">kpi.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>

    <record id="view_kpi_team_form" model="ir.ui.view">
        <field name="name">kpi.team.form</field>
        <field name="model">kpi.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids">
                                <tree editable="bottom">
                                    <field name="employee_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_team" model="ir.actions.act_window">
        <field name="name">KPI Teams</field>
        <field name="res_model">kpi.team</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

