<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_definition_tree" model="ir.ui.view">
        <field name="name">kpi.definition.tree</field>
        <field name="model">kpi.definition</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="kpi_type"/>
                <field name="calculation_method"/>
                <field name="source_module"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_kpi_definition_form" model="ir.ui.view">
        <field name="name">kpi.definition.form</field>
        <field name="model">kpi.definition</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="kpi_type"/>
                        </group>
                        <group>
                            <field name="calculation_method"/>
                            <field name="source_module"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Target">
                            <field name="target_ids">
                                <tree editable="bottom">
                                    <field name="target_value"/>
                                    <field name="weight"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_definition" model="ir.actions.act_window">
        <field name="name">KPI Definitions</field>
        <field name="res_model">kpi.definition</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

