<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_department_tree" model="ir.ui.view">
        <field name="name">kpi.department.tree</field>
        <field name="model">kpi.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_kpi_department_form" model="ir.ui.view">
        <field name="name">kpi.department.form</field>
        <field name="model">kpi.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_department" model="ir.actions.act_window">
        <field name="name">KPI Departments</field>
        <field name="res_model">kpi.department</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

