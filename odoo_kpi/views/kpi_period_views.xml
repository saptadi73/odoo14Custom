<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_period_tree" model="ir.ui.view">
        <field name="name">kpi.period.tree</field>
        <field name="model">kpi.period</field>
        <field name="arch" type="xml">
            <tree>
                <field name="year"/>
                <field name="month"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_kpi_period_form" model="ir.ui.view">
        <field name="name">kpi.period.form</field>
        <field name="model">kpi.period</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="year"/>
                        <field name="month"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_period" model="ir.actions.act_window">
        <field name="name">KPI Periods</field>
        <field name="res_model">kpi.period</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

