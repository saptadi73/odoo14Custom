<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_target_tree" model="ir.ui.view">
        <field name="name">kpi.target.tree</field>
        <field name="model">kpi.target</field>
        <field name="arch" type="xml">
            <tree>
                <field name="kpi_definition_id"/>
                <field name="target_value"/>
                <field name="weight"/>
            </tree>
        </field>
    </record>

    <record id="view_kpi_target_form" model="ir.ui.view">
        <field name="name">kpi.target.form</field>
        <field name="model">kpi.target</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="kpi_definition_id"/>
                        <field name="target_value"/>
                        <field name="weight"/>
                    </group>
                    <notebook>
                        <page string="Target History">
                            <field name="history_ids">
                                <tree editable="bottom">
                                    <field name="year"/>
                                    <field name="target_value"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_target" model="ir.actions.act_window">
        <field name="name">KPI Targets</field>
        <field name="res_model">kpi.target</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

