    <record id="action_view_hr_potongan_form" model="ir.actions.act_window">
        <field name="name">Employee Other Deduction</field>
        <field name="res_model">hr.potongan</field>
        <field name="view_mode">tree,form</field>
<!--        <field name="search_view_id" ref="view_hr_potongan_filter"/>-->
    </record>

    <menuitem name="Other Deduction" id="menu_potongan_tree" parent="hr_payroll_community.menu_hr_payroll_community_root" />

    <menuitem action="action_view_hr_potongan_form" id="menu_potongan_karyawan_tree" parent="menu_potongan_tree" groups="hr_payroll_community.group_hr_payroll_community_user"/>


