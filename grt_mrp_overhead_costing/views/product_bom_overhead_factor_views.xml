<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_overhead_factor" model="ir.ui.view">
        <field name="name">product.template.form.overhead.factor</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="overhead_electricity_factor_default"/>
                <field name="overhead_labor_factor_default"/>
            </xpath>
        </field>
    </record>

    <record id="view_mrp_bom_form_overhead_factor" model="ir.ui.view">
        <field name="name">mrp.bom.form.overhead.factor</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_tmpl_id']" position="after">
                <field name="overhead_electricity_factor_default"/>
                <field name="overhead_labor_factor_default"/>
            </xpath>
        </field>
    </record>
</odoo>