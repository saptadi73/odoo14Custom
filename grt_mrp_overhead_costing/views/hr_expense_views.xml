<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_expense_form_mrp_overhead" model="ir.ui.view">
        <field name="name">hr.expense.form.mrp.overhead</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="mrp_overhead_type_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_expense_tree_mrp_overhead" model="ir.ui.view">
        <field name="name">hr.expense.tree.mrp.overhead</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.view_expenses_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="mrp_overhead_type_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_expense_sheet_form_mrp_overhead" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.mrp.overhead</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="mrp_overhead_type_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_mrp_overhead" model="ir.ui.view">
        <field name="name">account.move.form.mrp.overhead</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="mrp_overhead_type_id"/>
                <field name="mrp_overhead_period_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
