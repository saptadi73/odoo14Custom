<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_paumnet_add_method_of_payment" model="ir.ui.view">
        <field name="name">account.paumnet.add.method.of.paynet</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
        	 <xpath expr="//header//button[@name='action_post']" position="replace">
                <button name="action_post" string="Confirm" type="object" class="oe_highlight" attrs="{'invisible': ['|',('state', '!=', 'draft'),('payment_for','=',True)]}"/>
                <button name="dev_generate_moves" string="Confirm" 
                        type="object" class="oe_highlight"
                        attrs="{'invisible': ['|',('state', '!=', 'draft'),('payment_for','!=',True)]}"/>
            </xpath>
        	<xpath expr="//group//group[@name='group3']//label" position="before">
        		<field name="payment_for" attrs="{'readonly':[('state','!=','draft')]}"/>
        	</xpath>
        	<xpath expr="//group[@name='group2']//field[@name='move_id']" position="replace">
        	    <field name="move_id" required="0" 
        	           attrs="{'invisible': ['|',('id', '=', False),('state','=','draft')]}" groups="account.group_account_readonly"/>
        	</xpath>
             <xpath expr="//sheet" position="inside">
             	<notebook colspan="4" attrs="{'invisible':[('payment_for','!=',True)]}">
				   <page string="Payment Item"> 
				        <group> 
				            <group>
				                <button type="object" string='Load Lines' name="load_payment_lines" attrs="{'invisible':[('state','=','posted')]}" class="oe_highlight"/>
				            </group>
				        </group>
				        
		             	<field name="payment_line_ids" nolabel="1" attrs="{'readonly':[('state','!=','draft')],'invisible':[('payment_for','!=',True)]}">
		                    <tree editable="bottom">
		                    	 <!-- <field name="tipe_invoice"/> -->
		                         <field name="invoice_id"/>
		                         <!-- <field name="account_id" /> -->
		                         <field name="date" />
		                         <field name="due_date" />
		                         <field name="original_amount" sum="Amount"/>
			                     <field name="balance_amount" sum="Balance"/>
			                     <field name="allocation" sum="Allocation"/>
			                     <field name="diff_amt" sum="Different"/>
		                    </tree>
		                </field>
		            </page>
		        </notebook>
            </xpath>
               
        </field>
    </record>


    <record id="view_invoice_sapi" model="ir.ui.view">
      <field name="name">Invoice Inherite Sapi</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <field name="payment_reference" position="after"> 
             <field name="tipe_inv_id"/>
        </field>
      </field>
      
    </record>


</odoo>
