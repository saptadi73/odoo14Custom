<odoo>
  <data>

     <record id="view_inherite_setoran" model="ir.ui.view">
        <field name="name">Setoran Inherite Form</field>
        <field name="model">liter.sapi</field>
        <field name="inherit_id" ref="liter_sapi.view_liter_sapi_form"/>
        <field name="arch" type="xml">
          <xpath expr="/form/" position="after">
                <header>
                  <field name="purchase_count" invisible="1"/>
                  <button name="create_po" string="Create PO" type="object" class="oe_highlight" attrs="{'invisible': [('purchase_count', '!=', 0)]}"/>
                </header>
          </xpath>
        </field>
    </record>
  
  </data>
</odoo>