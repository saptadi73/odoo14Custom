<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_stage_view_form_business_category" model="ir.ui.view">
        <field name="name">crm.stage.form.business.category</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='team_id']" position="before">
                <field name="company_id" invisible="1"/>
                <field name="business_category_id" domain="[('company_id', '=', company_id)]"/>
            </xpath>
            <xpath expr="//field[@name='team_id']" position="attributes">
                <attribute name="domain">[('company_id', '=', company_id), ('business_category_id', '=', business_category_id)]</attribute>
            </xpath>
        </field>
    </record>

    <record id="crm_stage_view_tree_business_category" model="ir.ui.view">
        <field name="name">crm.stage.tree.business.category</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="company_id" optional="show"/>
                <field name="business_category_id" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
