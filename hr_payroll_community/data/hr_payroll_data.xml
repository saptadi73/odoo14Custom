        <record id="hr_rule_basic" model="hr.salary.rule">
            <field name="name">Basic Salary</field>
            <field name="sequence" eval="1"/>
            <field name="code">BASIC</field>
            <field name="category_id" ref="hr_payroll_community.BASIC"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = contract.wage</field>
        </record>

        <record id="hr_rule_taxable" model="hr.salary.rule">
            <field name="name">Gross</field>
            <field name="sequence" eval="195"/>
            <field name="code">GROSS</field>
            <field name="category_id" ref="hr_payroll_community.GROSS"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = (categories.GAPOK + categories.ALW + categories.PNR + categories.BTH + categories.TP)</field>
        </record>

        <record id="hr_rule_net" model="hr.salary.rule">
            <field name="name">Net Salary</field>
            <field name="sequence" eval="200"/>
            <field name="code">NET</field>
            <field name="category_id" ref="hr_payroll_community.NET"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = (categories.GAPOK + categories.ALW  + categories.PNR + categories.BTH) - (categories.DED + categories.PINJ + categories.POT + categories.POTLAN + categories.ZKT + categories.PPh) if categories.PPh >= 0 else (categories.GAPOK + categories.ALW  + categories.PNR + categories.BTH) - ((categories.DED + categories.PINJ + categories.POT + categories.POTLAN + categories.ZKT) + (-1 * categories.PPh))</field>
            <field name="register_id" ref="contrib_register_employees"/>
        </record>

