            <field name="category_id" ref="hr_payroll_community.Pajak-Kembali"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">if not contract.employee_id.address_home_id.vat:
    result = (round((categories.TPPP - categories.PREPPH) - ((categories.TPPP - categories.PREPPH) / 1.25),0) * -1) if (categories.TPPP - categories.PREPPH) &lt; 0 else 0
else:
    result = 0</field>
