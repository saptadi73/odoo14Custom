        <record id="hr_rule_ZKT" model="hr.salary.rule">
            <field name="name">Potongan Zakat</field>
            <field name="sequence" eval="105"/>
            <field name="code">ZKT</field>
            <field name="category_id" ref="hr_payroll_community.Zakat"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">if contract.use_zakat == True:
  if contract.type_id.name=='ZKTSPS':
     result = round(((categories.GAPOK + categories.ALW + (contract.dsr_pensiun * contract.p_pen1) + (contract.dsr_bpjs * contract.p_bpjs)) - ((categories.DED + categories.PPh) + (contract.dsr_bpjs *  contract.p_bpjs1)))*0.025) 
  else:
     result = round(((categories.GAPOK + categories.ALW + (contract.dsr_pensiun * contract.p_pen1)) - (categories.DED + categories.PPh))*0.025)
else:
     result = 0.0</field>
        </record>		
