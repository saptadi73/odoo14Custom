        <record id="hr_rule_PNLT" model="hr.salary.rule">
            <field name="name">Penalti PPH21</field>
            <field name="sequence" eval="151"/>
            <field name="code">PNLT</field>
            <field name="category_id" ref="hr_payroll_community.DED"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">if not contract.employee_id.address_home_id.vat:
    result = 0 if categories.TP &lt; 0 else round(categories.TP - (categories.TP / 1.25),0)
else:
    result = 0.0</field>
        </record>	
