			<field name="appears_on_payslip" eval="False"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">prev_thn = int(str(payslip.date_from)[:-6])
cur_bln = int(str(payslip.date_from)[-5:-3])
prev_bln = cur_bln - 1
if prev_bln &lt;1:
   prev_bln = 1
start_date = str(prev_thn) + "-" + str(prev_bln).zfill(2) + "-01"
end_date = str(payslip.date_from)[:-3] + "-01"

result = payslip.sum('TLLDSB',start_date,end_date)</field>
        </record>		
