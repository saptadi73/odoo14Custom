        <record id="hr_rule_PPHT1" model="hr.salary.rule">
            <field name="name">PPH 21 Tahap 1</field>
            <field name="sequence" eval="5"/>
            <field name="code">PPHT1</field>
            <field name="category_id" ref="hr_payroll_community.Non-Karyawan"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">bruto=contract.wage*0.20*0.02*0.5
pkp = int((bruto - contract.ptkp_rate)/1000) * 1000
if pkp > 0 and pkp &lt;= 50000000:
   cp21= round((pkp * 0.05),2)
elif pkp >50000000 and (pkp - 50000000) &lt;= 200000000:
   cp21= round(((50000000*0.05)+((pkp-50000000)* 0.15)),2) 
elif pkp >200000000 and (pkp - 250000000) &lt;= 250000000:
   cp21= round(((50000000*0.05)+(200000000 * 0.15)+((pkp-250000000)*0.25)),2)
elif pkp >250000000 and (pkp - 500000000) &lt;= 1000000000:
   cp21= round(((50000000*0.05)+(200000000 * 0.15)+(250000000 * 0.25)+((pkp-500000000)*0.3)), 2)
else:
   cp21= 0.00

result=cp21</field>
        </record>	
