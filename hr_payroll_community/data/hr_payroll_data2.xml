        <record id="hr_rule_GROSS" model="hr.salary.rule">
            <field name="name">Gross</field>
            <field name="sequence" eval="195"/>
            <field name="code">GROSS</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.GROSS"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = (categories.GAPOK + categories.ALW + categories.PNR + categories.TP + categories.PAKEM) + (categories.BTH - THRPP - BNSPP)</field>
        </record>

        <record id="hr_rule_net" model="hr.salary.rule">
            <field name="name">Net Salary</field>
            <field name="sequence" eval="200"/>
            <field name="code">NET</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.NET"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = round(GROSS - (categories.DED + categories.PINJ + categories.POT + categories.POTLAN + categories.ZKT + categories.PPh),0)</field>
            <field name="register_id" ref="contrib_register_employees"/>
        </record>
		
        <record id="hr_rule_TPens" model="hr.salary.rule">
            <field name="name">Tunjangan Pensiun 2%</field>
            <field name="sequence" eval="1"/>
            <field name="code">TPens</field>
            <field name="category_id" ref="hr_payroll_community.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = round(contract.dsr_pensiun * (contract.t_pen / 100))</field>
        </record>

        <record id="hr_rule_TJHT" model="hr.salary.rule">
            <field name="name">Tunjangan JHT 3.7%</field>
            <field name="sequence" eval="5"/>
            <field name="code">TJHT</field>
            <field name="category_id" ref="hr_payroll_community.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = round(contract.dsr_bpjstk * (contract.t_jht / 100))</field>
        </record>

       <record id="hr_rule_PGR" model="hr.salary.rule">
            <field name="name">Pengurang</field>
            <field name="sequence" eval="109"/>
            <field name="code">PGR</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = categories.PEN + categories.PPEN</field>
        </record>

        <record id="hr_rule_JBT" model="hr.salary.rule">
            <field name="name">Biaya Jabatan</field>
            <field name="sequence" eval="109"/>
            <field name="code">JBT</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result=0.00 if (contract.type_id.name=='PHL' or contract.type_id.name=='NONK') else categories.BJB + categories.PREJAB</field>
        </record>

        <record id="hr_rule_PREBRT" model="hr.salary.rule">
            <field name="name">Prev_brt</field>
            <field name="sequence" eval="109"/>
            <field name="code">PREBRT</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">p21=0.00 
result=((categories.GAPOK + categories.PNR) + ((categories.PBRUT - categories.PPHA))) + p21</field>
        </record>

        <record id="hr_rule_TLLDSB" model="hr.salary.rule">
            <field name="name">Tunla/Lembur/dsb</field>
            <field name="sequence" eval="109"/>
            <field name="code">TLLDSB</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = categories.PNR + TLOK + TT + TM + TJ + TUNLA + categories.PTTLDSB</field>
        </record>

        <record id="hr_rule_CBTH" model="hr.salary.rule">
            <field name="name">THR/Bonus</field>
            <field name="sequence" eval="109"/>
            <field name="code">CBTH</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = categories.BTH + categories.PREBTH</field>
        </record>

        <record id="hr_rule_PRMA" model="hr.salary.rule">
            <field name="name">Premi Asuransi</field>
            <field name="sequence" eval="109"/>
            <field name="code">PRMA</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = TJKM + TJKK + TDPLK + TBPJSKes + categories.PPRM</field>
        </record>

        <record id="hr_rule_JM1" model="hr.salary.rule">
            <field name="name">Jumlah 1</field>
            <field name="sequence" eval="122"/>
            <field name="code">JM1</field>
			<field name="appears_on_payslip" eval="False"/>
            <field name="category_id" ref="hr_payroll_community.COMP"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = BRTA -  ((TLOK + TJKM + TJKK + TDPLK + TBPJSKes + categories.PPRM) + (categories.PNR + TT + TM + TJ + TUNLA + categories.PTTLDSB) + PPH21GU)</field>
        </record>
	
        <record id="hr_rule_PPh" model="hr.salary.rule">
            <field name="name">PPh21</field>
            <field name="sequence" eval="150"/>
            <field name="code">PPh</field>
            <field name="category_id" ref="hr_payroll_community.PPh"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = round(categories.TPPP - categories.PREPPH,0)</field>
        </record>
		

    </data>
</odoo>
