<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_cip_to_asset_tree" model="ir.ui.view">
            <field name="name">cip.to.asset.tree</field>
            <field name="model">cip.to.asset</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="CIP">
                    <field name="name"/>
                    <field name="eartag_id"/>
                    <field name="sapi_id"/>
                    <field name="category_asset_id"/>
                </tree>
            </field>
        </record>

        <record id="view_cip_to_asset_form" model="ir.ui.view">
            <field name="name">cip.to.asset.form</field>
            <field name="model">cip.to.asset</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="CIP">
                    <header>
                        <button name="func_posted" type="object" string="Posted" class="oe_highlight" confirm="Apakah Data Sudah OK?" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                        <button name="func_cancel" type="object" string="Cancel" class="oe_highlight" confirm="Apakah Anda Yakin Ingin Membatalkan Transaksi?" attrs="{'invisible': [('state', '!=', 'posted')]}"/>
                        <button name="func_set_draft" type="object" string="Set to Draft" class="oe_highlight" confirm="Apakah Anda Yakin Ingin Menjadi Draft?" attrs="{'invisible': [('state', '!=', 'cancel')]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel"/>
                        <button string="Generate CIP to Asset" type="object" class="oe_highlight"
                        icon="fa-magic" name="generate_to_asset"/>
                        <button string="Generate Journal" type="object" class="oe_highlight"
                        icon="fa-magic" name="generate_journal_entry"/>
                    </header>
                    <sheet>
                        <group col="4">
                            <field name="name" required="1" attrs="{'readonly':[('state','not in',['draft'])]}"/>
                            <field name="date" required="1" attrs="{'readonly':[('state','not in',['draft'])]}"/>
                            <field name="eartag_id" required="1" attrs="{'readonly':[('state','not in',['draft'])]}"/>
                            <field name="sapi_id" readonly="0" attrs="{'readonly':[('state','not in',['draft'])]}"/>
                            <field name="category_cip_id" required="1" attrs="{'readonly':[('state','not in',['draft'])]}"/>
                            <field name="category_asset_id" required="1" attrs="{'readonly':[('state','not in',['draft'])]}"/>
                        </group>
                        <group>
                            <field name="journal_entry"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_cip_to_asset_search" model="ir.ui.view">
            <field name="name">cip.to.asset.search</field>
            <field name="model">cip.to.asset</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="CIP">
                    <field name="name"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Asset" name="group_by_name"
                                domain="[]" context="{'group_by':'name'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_cip_to_asset_pivot" model="ir.ui.view">
            <field name="name">cip.to.asset.pivot</field>
            <field name="model">cip.to.asset</field>
            <field name="arch" type="xml">
                <pivot>

                </pivot>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cip_to_asset_view">
            <field name="name">CIP to Asset</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cip.to.asset</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="search_view_id" ref="view_cip_to_asset_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_cip_to_asset_view_form">
            <field name="act_window_id" ref="act_cip_to_asset_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_cip_to_asset_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_cip_to_asset_view_tree">
            <field name="act_window_id" ref="act_cip_to_asset_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_cip_to_asset_tree"/>
        </record>

        <menuitem id="menu_cip_to_asset_details"
                    name="CIP to Asset"
                    parent="menu_cip_details"
                    sequence="20"
                    action="act_cip_to_asset_view"/>
    </data>
</odoo>