<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_cip_tree" model="ir.ui.view">
            <field name="name">cip.tree</field>
            <field name="model">cip</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="CIP">
                    <field name="date"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="account_analytic_id"/>
                    <field name="eartag_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_cip_form" model="ir.ui.view">
            <field name="name">cip.form</field>
            <field name="model">cip</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="CIP">
                    <header>
                        <button name="func_calculate" type="object" string="Calculate" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                        <button name="func_validate" type="object" string="Validate" class="oe_highlight" confirm="Apakah Data Sudah OK?" attrs="{'invisible': [('state', '!=', 'calculate')]}"/>
                        <button name="func_done" type="object" string="Done" class="oe_highlight" confirm="Apakah Data Sudah OK?" attrs="{'invisible': [('state', '!=', 'validate')]}"/>
                        <button name="func_cancel" type="object" string="Cancel" class="oe_highlight" confirm="Apakah Anda Yakin Ingin Membatalkan Transaksi?" attrs="{'invisible': [('state', '!=', 'done')]}"/>
                        <button name="func_set_draft" type="object" string="Set to Draft" class="oe_highlight" confirm="Apakah Anda Yakin Ingin Menjadi Draft?" attrs="{'invisible': [('state', '!=', 'cancel')]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,calculate,validate,done,cancel"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="date" required="1"/>
                        </group>
                        <group col="4">
                            <field name="date_from" required="1"/>
                            <field name="date_to" required="1"/>
                            <field name="sapi_ids" widget="many2many_tags" required="1"/>
                            <field name="eartag_id"/>
                        </group>
                        <group col="4">
                            <field name="account_analytic_id" required="1"/>
                            <field name="company_id"/>
                        </group>
                        <group col="6">
                            <field name="jum_sapi_dara"/>
                            <field name="jum_sapi_pedet"/>
                            <field name="jum_sapi_induk"/>
                            <field name="jum_sapi"/>
                        </group>
                        <group col="6">
                            <field name="amount_dara"/>
                            <field name="amount_pedet"/>
                            <field name="amount_induk"/>
                        </group>
                        <group col="4">
                            <field name="tot_amount"/>
                            <field name="tot_hhp_sapi"/>
                        </group>
                        <notebook>
                            <page string="List Expense">
                                <group >
                                    <button string="Get Rearing Transactions" type="object" class="oe_highlight" name="button_get_rearing_transactions"/>
                                </group>
                                <group >
                                    <button string="Generate Journal Dara" type="object" class="oe_highlight" name="generate_journal_entry"/>
                                    <field name="move_id"/>
                                </group>
                                <group >
                                    <button string="Generate Journal Pedet" type="object" class="oe_highlight" name="generate_journal_entry_pedet"/>
                                    <field name="move_id_pedet"/>
                                </group>
                                <group >
                                    <button string="Generate Journal Induk" type="object" class="oe_highlight" name="generate_journal_entry_induk"/>
                                    <field name="move_id_induk"/>
                                </group>
                                <group>
                                    <field name="cip_expense_line_ids" nolabel="1" options="{'reload_on_button': True}">
                                        <tree edit="true" editable="bottom" create="true" delete="true">
                                            <field name="date_from"/>
                                            <field name="date_to"/>
                                            <field name="account_id"/>
                                            <field name="account_analytic_id"/>
                                            <field name="debit"/>
                                            <field name="credit"/>
                                            <field name="balance"/>
                                            <field name="hhp_sapi"/>
                                        </tree>
                                    </field>
                                </group>
                            </page>
                            <page string="List HPP">
                                <button string="Generate HPP Lines" type="object" class="oe_highlight"
                                        icon="fa-magic" name="generate_cip_hpp_lines"/>
                                <group>
                                    <field name="cip_hpp_line_ids" nolabel="1" options="{'reload_on_button': True}">
                                        <tree edit="true" editable="bottom" create="true" delete="true">
                                            <field name="eartag_id"/>
                                            <field name="sapi_id"/>
                                            <field name="category_cip_id"/>
                                            <field name="status_sapi"/>
                                            <field name="date"/>
                                            <field name="amount"/>
                                        </tree>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_cip_search" model="ir.ui.view">
            <field name="name">cip.search</field>
            <field name="model">cip</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="CIP">
                    <field name="eartag_id"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Eartag ID" name="group_by_eartag_id"
                                domain="[]" context="{'group_by':'eartag_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_cip_pivot" model="ir.ui.view">
            <field name="name">liter.pivot</field>
            <field name="model">cip</field>
            <field name="arch" type="xml">
                <pivot>

                </pivot>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cip_view">
            <field name="name">HPP Expense</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cip</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="search_view_id" ref="view_cip_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_cip_view_form">
            <field name="act_window_id" ref="act_cip_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_cip_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_cip_view_tree">
            <field name="act_window_id" ref="act_cip_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_cip_tree"/>
        </record>

        <menuitem id="menu_cip_asset_details"
                    name="HPP Expense"
                    parent="menu_cip_details"
                    sequence="10"
                    action="act_cip_view"/>
    </data>
</odoo>