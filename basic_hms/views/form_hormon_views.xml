<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_hormon_view" model="ir.ui.view">
            <field name="name">form.hormon.form.view</field>
            <field name="model">form.hormon</field>
            <field name="arch" type="xml">
                <form string="Form Hormon">
                    <sheet>
                        <group>
                            <group>
                                <field name="peternak_id"/>
                                <field name="id_pemilik"/>
                                <field name="petugas_id"/>
                                <field name="jabatan_id"/>
                                <field name="tgl_layanan"/>
                            </group>
                            <group>
                                <field name="id_sapi"/>
                                <field name="eartag_id"/>
                                <field name="tps_id"/>
                                <field name="bcs"/>
                                <field name="cat_petugas"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="form_hormon_search_view" model="ir.ui.view">
            <field name="name">form.hormon.search.view</field>
            <field name="model">form.hormon</field>
            <field name="arch" type="xml">
                <search string="Search Hormon">
                    <separator orientation="vertical" />
                    <field name="eartag_id" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="ID Sapi" name='by_eartag_id' context="{'group_by':'eartag_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="form_hormon_tree_view" model="ir.ui.view">
            <field name="name">form.hormon.tree.view</field>
            <field name="model">form.hormon</field>
            <field name="arch" type="xml">
                <tree string="Form Hormon">
                     <field name="id_pemilik"/>
                    <field name="eartag_id"/>
                    <field name="tgl_layanan"/>
                    <field name="cat_petugas"/>
                </tree>
            </field>
        </record>

        <record id="view_form_hormon_pivot" model="ir.ui.view">
        <field name="name">form.hormon.pivot</field>
        <field name="model">form.hormon</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="tgl_layanan" type="col"/>
                <field name="petugas_id" type="row"/>
                <field name="jabatan_id" type="col"/>
                <field name="petugas_id" type="count"/>
            </pivot>
        </field>
    </record>

        <record id="action_form_hormon" model="ir.actions.act_window">
            <field name="name">Form Hormon</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">form.hormon</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_form_hormon" parent="menu_layanan"
            action="action_form_hormon" sequence="90" />

</odoo>