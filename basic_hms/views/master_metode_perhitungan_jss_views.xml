<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_metode_perhitungan_jss_view" model="ir.ui.view">
            <field name="name">form.master.metode.perhitungan.jss.view</field>
            <field name="model">master.metode.perhitungan.jss</field>
            <field name="arch" type="xml">
                <form string="Form Master Metode Perhitungan JSS">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_metode_perhitungan_jss"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_metode_perhitungan_jss_search_view" model="ir.ui.view">
            <field name="name">master.metode.perhitungan.jss.search.view</field>
            <field name="model">master.metode.perhitungan.jss</field>
            <field name="arch" type="xml">
                <search string="Search Master Metode Perhitungan JSS">
                    <separator orientation="vertical" />
                    <field name="nama_metode_perhitungan_jss" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Metode Perhitungan JSS" name='by_nama_metode_perhitungan_jss' context="{'group_by':'nama_metode_perhitungan_jss'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_metode_perhitungan_jss_tree_view" model="ir.ui.view">
            <field name="name">master.metode.perhitungan.jss.tree.view</field>
            <field name="model">master.metode.perhitungan.jss</field>
            <field name="arch" type="xml">
                <tree string="Form Master Metode Perhitungan JSS">
                    <field name="kode"/>
                    <field name="nama_metode_perhitungan_jss"/>
                </tree>
            </field>
        </record>

        <record id="action_master_metode_perhitungan_jss" model="ir.actions.act_window">
            <field name="name">Master Metode Perhitungan JSS</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.metode.perhitungan.jss</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_metode_perhitungan_jss" parent="mster_data"
            action="action_master_metode_perhitungan_jss" sequence="19" />

</odoo>