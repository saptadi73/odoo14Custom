<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_kode_kelahiran_view" model="ir.ui.view">
            <field name="name">form.master.kode.kelahiran.view</field>
            <field name="model">master.kode.kelahiran</field>
            <field name="arch" type="xml">
                <form string="Form Master Kode Kelahiran">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_kode_kelahiran"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_kode_kelahiran_search_view" model="ir.ui.view">
            <field name="name">master.kode.kelahiran.search.view</field>
            <field name="model">master.kode.kelahiran</field>
            <field name="arch" type="xml">
                <search string="Search Master Kode Kelahiran">
                    <separator orientation="vertical" />
                    <field name="nama_kode_kelahiran" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Kode Kelahiran" name='by_nama_kode_kelahiran' context="{'group_by':'nama_kode_kelahiran'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_kode_kelahiran_tree_view" model="ir.ui.view">
            <field name="name">master.kode.kelahiran.tree.view</field>
            <field name="model">master.kode.kelahiran</field>
            <field name="arch" type="xml">
                <tree string="Form Master Kode Kelahiran">
                    <field name="kode"/>
                    <field name="nama_kode_kelahiran"/>
                </tree>
            </field>
        </record>

        <record id="action_master_kode_kelahiran" model="ir.actions.act_window">
            <field name="name">Master Kode Kelahiran</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.kode.kelahiran</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_kode_kelahiran" parent="mster_data"
            action="action_master_kode_kelahiran" sequence="22" />

</odoo>