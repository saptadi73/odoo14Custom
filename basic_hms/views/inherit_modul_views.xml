<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_picking_form_tipesapi" model="ir.ui.view">
            <field name="name">stock.picking.tipesapi.form</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='product_id']" position="after">
                    <field name="tipe_id"/>
                    <field name="sapi_ids" widget="many2many_tags"/>
                    <field name="eartag_id"/>
                </xpath>
                <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='product_uom']" position="after">
                    <field name="inventory_qty"/>
                    <field name="price"/>
                    <field name="tot_price"/>
                    <field name="is_pakan"/>
                </xpath>
            </field>
        </record>

        <record id="view_move_tipesapi_form" model="ir.ui.view">
            <field name="name">stock.move.tipesapi.form</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='location_dest_id']" position="after">
                    <field name="tipe_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_picking_form_pakan" model="ir.ui.view">
            <field name="name">stock.picking.pakan.form</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='operations']" position="after">
                    <page name="pakan" string="Pakan">
                        <group>
                            <field name="tipe_id" required="0"/>
                            <field name="sapi_ids" widget="many2many_tags" required="0"/>
                            <field name="eartag_id"/>
                            <field name="product_pakan_id" required="0"/>
                            <field name="standard_price"/>
                            <field name="qty" required="0"/>
                            <field name="price"/>
                            <field name="jum_sapi"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
