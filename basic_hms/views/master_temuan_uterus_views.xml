<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_temuan_uterus_view" model="ir.ui.view">
            <field name="name">form.master.temuan.uterus.view</field>
            <field name="model">master.temuan.uterus</field>
            <field name="arch" type="xml">
                <form string="Form Master Temuan Uterus">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_temuan_uterus"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_temuan_uterus_search_view" model="ir.ui.view">
            <field name="name">master.temuan.uterus.search.view</field>
            <field name="model">master.temuan.uterus</field>
            <field name="arch" type="xml">
                <search string="Search Master Temuan Uterus">
                    <separator orientation="vertical" />
                    <field name="nama_temuan_uterus" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Temuan Uterus" name='by_nama_temuan_uterus' context="{'group_by':'nama_temuan_uterus'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_temuan_uterus_tree_view" model="ir.ui.view">
            <field name="name">master.temuan.uterus.tree.view</field>
            <field name="model">master.temuan.uterus</field>
            <field name="arch" type="xml">
                <tree string="Form Master Temuan Uterus">
                    <field name="kode"/>
                    <field name="nama_temuan_uterus"/>
                </tree>
            </field>
        </record>

        <record id="action_master_temuan_uterus" model="ir.actions.act_window">
            <field name="name">Master Temuan Uterus</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.temuan.uterus</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_temuan_uterus" parent="mster_data"
            action="action_master_temuan_uterus" sequence="16" />

</odoo>