<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_specimen_view" model="ir.ui.view">
            <field name="name">form.master.specimen.view</field>
            <field name="model">master.specimen</field>
            <field name="arch" type="xml">
                <form string="Form Master Specimen">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_specimen"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_specimen_search_view" model="ir.ui.view">
            <field name="name">master.specimen.search.view</field>
            <field name="model">master.specimen</field>
            <field name="arch" type="xml">
                <search string="Search Master Specimen">
                    <separator orientation="vertical" />
                    <field name="nama_specimen" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Specimen" name='by_nama_specimen' context="{'group_by':'nama_specimen'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_specimen_tree_view" model="ir.ui.view">
            <field name="name">master.specimen.tree.view</field>
            <field name="model">master.specimen</field>
            <field name="arch" type="xml">
                <tree string="Form Master Specimen">
                    <field name="kode"/>
                    <field name="nama_specimen"/>
                </tree>
            </field>
        </record>

        <record id="action_master_specimen" model="ir.actions.act_window">
            <field name="name">Master Specimen</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.specimen</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_master_specimen" parent="mster_data"
            action="action_master_specimen" sequence="8" />

</odoo>