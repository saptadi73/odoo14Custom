<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_jabatan_view" model="ir.ui.view">
            <field name="name">form.master.jabatan.view</field>
            <field name="model">master.jabatan</field>
            <field name="arch" type="xml">
                <form string="Form Master Petugas">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_jabatan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_jabatan_search_view" model="ir.ui.view">
            <field name="name">master.jabatan.search.view</field>
            <field name="model">master.jabatan</field>
            <field name="arch" type="xml">
                <search string="Search Master Petugas">
                    <separator orientation="vertical" />
                    <field name="nama_jabatan" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="jabatan" name='by_nama_jabatan' context="{'group_by':'nama_jabatan'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_jabatan_tree_view" model="ir.ui.view">
            <field name="name">master.jabatan.tree.view</field>
            <field name="model">master.jabatan</field>
            <field name="arch" type="xml">
                <tree string="Form Master Petugas">
                    <field name="kode"/>
                    <field name="nama_jabatan"/>
                </tree>
            </field>
        </record>

        <record id="action_master_jabatan" model="ir.actions.act_window">
            <field name="name">Master Petugas</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.jabatan</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="menu_physician" name='Petugas'
            parent="main_menu_configartion" sequence="7" />
        <menuitem id="menu_master_master_jabatan" parent="menu_physician"
            action="action_master_jabatan" sequence="1" />

</odoo>