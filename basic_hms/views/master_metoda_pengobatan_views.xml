<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_metoda_pengobatan_view" model="ir.ui.view">
            <field name="name">form.master.metoda.pengobatan.view</field>
            <field name="model">master.metoda.pengobatan</field>
            <field name="arch" type="xml">
                <form string="Form Master Metoda Pengobatan">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_metoda_pengobatan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_metoda_pengobatan_search_view" model="ir.ui.view">
            <field name="name">master.metoda.pengobatan.search.view</field>
            <field name="model">master.metoda.pengobatan</field>
            <field name="arch" type="xml">
                <search string="Search Master Metoda Pengobatan">
                    <separator orientation="vertical" />
                    <field name="nama_metoda_pengobatan" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Metoda Pengobatan" name='by_nama_metoda_pengobatan' context="{'group_by':'nama_metoda_pengobatan'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_metoda_pengobatan_tree_view" model="ir.ui.view">
            <field name="name">master.metoda.pengobatan.tree.view</field>
            <field name="model">master.metoda.pengobatan</field>
            <field name="arch" type="xml">
                <tree string="Form Master Metoda Pengobatan">
                    <field name="kode"/>
                    <field name="nama_metoda_pengobatan"/>
                </tree>
            </field>
        </record>

        <record id="action_master_metoda_pengobatan" model="ir.actions.act_window">
            <field name="name">Master Metoda Pengobatan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.metoda.pengobatan</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_metoda_pengobatan" parent="mster_data"
            action="action_master_metoda_pengobatan" sequence="13" />

</odoo>