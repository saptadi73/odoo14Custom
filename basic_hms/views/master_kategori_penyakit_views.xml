<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_kategori_penyakit_view" model="ir.ui.view">
            <field name="name">form.master.kategori.penyakit.view</field>
            <field name="model">master.kategori.penyakit</field>
            <field name="arch" type="xml">
                <form string="Form Master Kategori Penyakit">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_kategori_penyakit"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_kategori_penyakit_search_view" model="ir.ui.view">
            <field name="name">master.kategori.penyakit.search.view</field>
            <field name="model">master.kategori.penyakit</field>
            <field name="arch" type="xml">
                <search string="Search Master Kategori Penyakit">
                    <separator orientation="vertical" />
                    <field name="nama_kategori_penyakit" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Kategori Penyakit" name='by_nama_kategori_penyakit' context="{'group_by':'nama_kategori_penyakit'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_kategori_penyakit_tree_view" model="ir.ui.view">
            <field name="name">master.kategori.penyakit.tree.view</field>
            <field name="model">master.kategori.penyakit</field>
            <field name="arch" type="xml">
                <tree string="Form Master Kategori Penyakit">
                    <field name="kode"/>
                    <field name="nama_kategori_penyakit"/>
                </tree>
            </field>
        </record>

        <record id="action_master_kategori_penyakit" model="ir.actions.act_window">
            <field name="name">Master Kategori Penyakit</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.kategori.penyakit</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_kategori_penyakit" parent="mster_data"
            action="action_master_kategori_penyakit" sequence="20" />

</odoo>