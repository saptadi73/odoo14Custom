<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_posisi_view" model="ir.ui.view">
            <field name="name">form.master.posisi.view</field>
            <field name="model">master.posisi</field>
            <field name="arch" type="xml">
                <form string="Form Master Posisi">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_posisi"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_posisi_search_view" model="ir.ui.view">
            <field name="name">master.posisi.search.view</field>
            <field name="model">master.posisi</field>
            <field name="arch" type="xml">
                <search string="Search Master Vaksin">
                    <separator orientation="vertical" />
                    <field name="nama_posisi" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Jenis Vaksin" name='by_nama_posisi' context="{'group_by':'nama_posisi'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_posisi_tree_view" model="ir.ui.view">
            <field name="name">master.posisi.tree.view</field>
            <field name="model">master.posisi</field>
            <field name="arch" type="xml">
                <tree string="Form Master Posisi">
                    <field name="kode"/>
                    <field name="nama_posisi"/>
                </tree>
            </field>
        </record>

        <record id="action_master_posisi" model="ir.actions.act_window">
            <field name="name">Master Posisi</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.posisi</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_master_posisi" parent="mster_data"
            action="action_master_posisi" sequence="4" />

</odoo>