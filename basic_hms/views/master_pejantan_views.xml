<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_pejantan_view" model="ir.ui.view">
            <field name="name">form.master.pejantan.view</field>
            <field name="model">master.pejantan</field>
            <field name="arch" type="xml">
                <form string="Form Master Pejantan">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_pejantan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_pejantan_search_view" model="ir.ui.view">
            <field name="name">master.pejantan.search.view</field>
            <field name="model">master.pejantan</field>
            <field name="arch" type="xml">
                <search string="Search Master Pejantan">
                    <separator orientation="vertical" />
                    <field name="nama_pejantan" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Abortus" name='by_nama_pejantan' context="{'group_by':'nama_pejantan'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_pejantan_tree_view" model="ir.ui.view">
            <field name="name">master.pejantan.tree.view</field>
            <field name="model">master.pejantan</field>
            <field name="arch" type="xml">
                <tree string="Form Master Pejantan">
                    <field name="kode"/>
                    <field name="nama_pejantan"/>
                </tree>
            </field>
        </record>

        <record id="action_master_pejantan" model="ir.actions.act_window">
            <field name="name">Master Pejantan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.pejantan</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_master_pejantan" parent="mster_data"
            action="action_master_pejantan" sequence="7" />

</odoo>