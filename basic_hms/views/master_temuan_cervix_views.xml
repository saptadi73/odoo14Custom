<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_temuan_cervix_view" model="ir.ui.view">
            <field name="name">form.master.temuan.cervix.view</field>
            <field name="model">master.temuan.cervix</field>
            <field name="arch" type="xml">
                <form string="Form Master Temuan Cervix">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_temuan_cervix"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_temuan_cervix_search_view" model="ir.ui.view">
            <field name="name">master.temuan.cervix.search.view</field>
            <field name="model">master.temuan.cervix</field>
            <field name="arch" type="xml">
                <search string="Search Master Temuan Cervix">
                    <separator orientation="vertical" />
                    <field name="nama_temuan_cervix" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Temuan Cervix" name='by_nama_temuan_cervix' context="{'group_by':'nama_temuan_cervix'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_temuan_cervix_tree_view" model="ir.ui.view">
            <field name="name">master.temuan.cervix.tree.view</field>
            <field name="model">master.temuan.cervix</field>
            <field name="arch" type="xml">
                <tree string="Form Master Temuan Cervix">
                    <field name="kode"/>
                    <field name="nama_temuan_cervix"/>
                </tree>
            </field>
        </record>

        <record id="action_master_temuan_cervix" model="ir.actions.act_window">
            <field name="name">Master Temuan Cervix</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.temuan.cervix</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_temuan_cervix" parent="mster_data"
            action="action_master_temuan_cervix" sequence="17" />

</odoo>