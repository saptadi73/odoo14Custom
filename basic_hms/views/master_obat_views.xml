<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="form_master_obat_view" model="ir.ui.view">
            <field name="name">form.master.obat.view</field>
            <field name="model">master.obat</field>
            <field name="arch" type="xml">
                <form string="Form Master Obat">
                    <sheet>
                        <group>
                            <field name="kode"/>
                            <field name="nama_obat"/>
                            <field name="kategori_obat_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="master_obat_search_view" model="ir.ui.view">
            <field name="name">master.obat.search.view</field>
            <field name="model">master.obat</field>
            <field name="arch" type="xml">
                <search string="Search Master Obat">
                    <separator orientation="vertical" />
                    <field name="nama_obat" select="1" />
                    <newline />
                    <group expand="1" string="Group By">
                        <filter string="Obat" name='by_nama_obat' context="{'group_by':'nama_obat'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="master_obat_tree_view" model="ir.ui.view">
            <field name="name">master.obat.tree.view</field>
            <field name="model">master.obat</field>
            <field name="arch" type="xml">
                <tree string="Form Master Obat">
                    <field name="kode"/>
                    <field name="nama_obat"/>
                    <field name="kategori_obat_id"/>
                </tree>
            </field>
        </record>

        <record id="action_master_obat" model="ir.actions.act_window">
            <field name="name">Master Obat</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.obat</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
        </record>

         <menuitem id="mster_data" name='Master Data'
            parent="main_menu_configartion" sequence="11" />
        <menuitem id="menu_master_obat" parent="mster_data"
            action="action_master_obat" sequence="12" />

</odoo>