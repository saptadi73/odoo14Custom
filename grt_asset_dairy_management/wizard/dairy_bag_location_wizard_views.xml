<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_dairy_bag_location_wizard_form" model="ir.ui.view">
        <field name="name">dairy.bag.location.wizard.form</field>
        <field name="model">dairy.bag.location.wizard</field>
        <field name="arch" type="xml">
            <form string="Buat Lokasi Tas Petugas">
                <group>
                    <field name="person_in_charge"/>
                    <field name="location_name"/>
                    <field name="parent_location_id"/>
                    <field name="company_id"/>
                </group>
                <footer>
                    <button name="action_create_location" type="object" string="Buat Lokasi" class="oe_highlight"/>
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dairy_bag_location_wizard" model="ir.actions.act_window">
        <field name="name">Buat Lokasi Tas Petugas</field>
        <field name="res_model">dairy.bag.location.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
