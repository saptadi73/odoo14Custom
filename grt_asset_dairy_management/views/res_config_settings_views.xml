<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_dairy_management" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.dairy.management</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Dairy Management" string="Dairy Management">
                    <h2>Dairy Management</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="dairy_concentrate_ratio"/>
                                <div class="text-muted">Rumus default kebutuhan pakan berdasarkan bobot badan sapi.</div>
                                <div class="content-group mt16">
                                    <field name="dairy_concentrate_ratio"/>
                                    <field name="dairy_grass_ratio"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="dairy_concentrate_product_id"/>
                                <div class="text-muted">Produk inventory yang dipakai saat posting pemberian pakan serta vitamin dan inseminasi.</div>
                                <div class="content-group mt16">
                                    <field name="dairy_concentrate_product_id"/>
                                    <field name="dairy_grass_product_id"/>
                                    <field name="dairy_vitamin_product_id"/>
                                    <field name="dairy_insemination_product_id"/>
                                    <field name="dairy_feed_source_location_id"/>
                                    <field name="dairy_feed_consumption_location_id"/>
                                    <field name="dairy_medical_source_location_id"/>
                                    <field name="dairy_medical_consumption_location_id"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="dairy_feed_journal_id"/>
                                <div class="text-muted">Jurnal dan akun otomatis untuk pakan, vitamin, inseminasi, serta kapitalisasi asset biologis.</div>
                                <div class="content-group mt16">
                                    <field name="dairy_feed_journal_id"/>
                                    <field name="dairy_capitalization_journal_id"/>
                                    <field name="dairy_treatment_journal_id"/>
                                    <field name="dairy_feed_inventory_account_id"/>
                                    <field name="dairy_feed_asset_account_id"/>
                                    <field name="dairy_feed_expense_account_id"/>
                                    <field name="dairy_vitamin_credit_account_id"/>
                                    <field name="dairy_vitamin_expense_account_id"/>
                                    <field name="dairy_insemination_credit_account_id"/>
                                    <field name="dairy_insemination_expense_account_id"/>
                                    <field name="dairy_analytic_account_id"/>
                                    <field name="dairy_meat_price_per_kg"/>
                                    <field name="dairy_impairment_journal_id"/>
                                    <field name="dairy_impairment_expense_account_id"/>
                                    <field name="dairy_impairment_allowance_account_id"/>
                                    <field name="dairy_impairment_recovery_account_id"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="dairy_asset_category_id"/>
                                <div class="text-muted">Kategori asset yang dipakai saat sapi mulai produksi atau melahirkan.</div>
                                <div class="content-group mt16">
                                    <field name="dairy_asset_category_id"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
