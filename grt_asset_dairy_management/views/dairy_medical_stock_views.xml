<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_dairy_medical_stock_transfer_tree" model="ir.ui.view">
        <field name="name">dairy.medical.stock.transfer.tree</field>
        <field name="model">dairy.medical.stock.transfer</field>
        <field name="arch" type="xml">
            <tree string="Distribusi Stok Medis ke Tas Petugas">
                <field name="name"/>
                <field name="date"/>
                <field name="person_in_charge"/>
                <field name="source_location_id"/>
                <field name="bag_location_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_dairy_medical_stock_transfer_form" model="ir.ui.view">
        <field name="name">dairy.medical.stock.transfer.form</field>
        <field name="model">dairy.medical.stock.transfer</field>
        <field name="arch" type="xml">
            <form string="Distribusi Stok Medis ke Tas Petugas">
                <header>
                    <button name="action_post" type="object" string="Post" states="draft" class="oe_highlight"/>
                    <button name="action_open_bag_location_wizard" type="object" string="Buat Lokasi Tas" states="draft"/>
                    <button name="action_cancel" type="object" string="Cancel" states="draft,posted"/>
                    <button name="action_reset_to_draft" type="object" string="Set Draft" states="cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="person_in_charge"/>
                            <field name="source_location_id"/>
                            <field name="bag_location_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="stock_move_ids" widget="many2many_tags" readonly="1"/>
                            <field name="reverse_stock_move_ids" widget="many2many_tags" readonly="1"/>
                            <field name="note"/>
                        </group>
                    </group>
                    <field name="line_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="product_uom_id" readonly="1"/>
                            <field name="qty"/>
                            <field name="note"/>
                        </tree>
                    </field>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_dairy_bag_stock_report_tree" model="ir.ui.view">
        <field name="name">dairy.bag.stock.report.tree</field>
        <field name="model">dairy.bag.stock.report</field>
        <field name="arch" type="xml">
            <tree string="Saldo Stok Tas Petugas" create="false" edit="false" delete="false">
                <field name="person_in_charge"/>
                <field name="bag_location_name"/>
                <field name="product_name"/>
                <field name="qty_on_hand"/>
                <field name="product_uom_id"/>
            </tree>
        </field>
    </record>

    <record id="view_dairy_bag_movement_report_tree" model="ir.ui.view">
        <field name="name">dairy.bag.movement.report.tree</field>
        <field name="model">dairy.bag.movement.report</field>
        <field name="arch" type="xml">
            <tree string="Mutasi Stok Tas Petugas" create="false" edit="false" delete="false">
                <field name="date"/>
                <field name="person_in_charge"/>
                <field name="bag_location_name"/>
                <field name="product_name"/>
                <field name="qty_in"/>
                <field name="qty_out"/>
                <field name="qty_signed"/>
                <field name="product_uom_id"/>
                <field name="reference"/>
                <field name="origin"/>
            </tree>
        </field>
    </record>

    <record id="action_dairy_medical_stock_transfer" model="ir.actions.act_window">
        <field name="name">Distribusi Stok Medis</field>
        <field name="res_model">dairy.medical.stock.transfer</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_dairy_bag_stock_report" model="ir.actions.act_window">
        <field name="name">Saldo Stok Tas Petugas</field>
        <field name="res_model">dairy.bag.stock.report</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="action_dairy_bag_movement_report" model="ir.actions.act_window">
        <field name="name">Mutasi Stok Tas Petugas</field>
        <field name="res_model">dairy.bag.movement.report</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
