<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_scada_mo_bulk_wizard_form" model="ir.ui.view">
        <field name="name">scada.mo.bulk.wizard.form</field>
        <field name="model">scada.mo.bulk.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Bulk Manufacturing Orders">
                <group>
                    <field name="product_id" options="{'no_create': True}"/>
                    <field name="product_qty"/>
                    <field name="max_qty_per_mo"/>
                    <field name="total_mo_count" readonly="1"/>
                    <field name="date_planned_start"/>
                    <field name="bom_id" options="{'no_create': True}"/>
                    <field name="scada_equipment_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_generate_mos" string="Generate MOs" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_scada_mo_bulk_wizard" model="ir.actions.act_window">
        <field name="name">Bulk MO Generator</field>
        <field name="res_model">scada.mo.bulk.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_scada_mo_bulk_wizard_form"/>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_scada_bulk_mo"
        parent="mrp.menu_mrp_production_action"
        name="Bulk MO Generator"
        action="action_scada_mo_bulk_wizard"
        sequence="60"
        groups="mrp.group_mrp_user,mrp.group_mrp_manager"/>
</odoo>
