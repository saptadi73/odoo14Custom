<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_tree_scada_product_tmpl_id" model="ir.ui.view">
        <field name="name">product.template.tree.scada.product.tmpl.id</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="id" string="product_tmpl_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_tree_scada_product_tmpl_id" model="ir.ui.view">
        <field name="name">product.product.tree.scada.product.tmpl.id</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_tmpl_id']" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="optional">show</attribute>
                <attribute name="string">product_tmpl_id</attribute>
            </xpath>
        </field>
    </record>
</odoo>
