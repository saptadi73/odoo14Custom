<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_service_conception_tree" model="ir.ui.view">
            <field name="name">service.conception.tree</field>
            <field name="model">service.conception</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="S/C (Service/ Conception)">
                    <field name="tgl_sc"/>
                    <field name="id_sapi"/>
                    <field name="tps_id"/>
                    <field name="ib_ke"/>
                    <field name="id_status_reproduksi"/>
                    <field name="nilai_sc"/>
                </tree>
            </field>
        </record>

        <record id="view_service_conception_form" model="ir.ui.view">
            <field name="name">service.conception.form</field>
            <field name="model">service.conception</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="S/C (Service/ Conception)">
                    <sheet>
                        <group col="4">
                            <field name="tgl_sc"/>
                            <field name="id_sapi"/>
                            <field name="tps_id"/>
                            <field name="ib_ke"/>
                            <field name="id_status_reproduksi"/>
                            <field name="nilai_sc"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_service_conception_search" model="ir.ui.view">
            <field name="name">service.conception.search</field>
            <field name="model">service.conception</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="S/C (Service/ Conception)">
                    <field name="id_sapi"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Sapi" name="group_by_sapi_id_group_name"
                                domain="[]" context="{'group_by':'id_sapi'}"/>
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_service_conception_view">
            <field name="name">S/C (Service/ Conception)</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">service.conception</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_service_conception_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_service_conception_view_form">
            <field name="act_window_id" ref="act_service_conception_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_service_conception_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_service_conception_view_tree">
            <field name="act_window_id" ref="act_service_conception_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_service_conception_tree"/>
        </record>

        <menuitem id="menu_service_conception_details"
                    name="S/C (Service/ Conception)"
                    parent="menu_sapi_formulasi_details"
                    sequence="10"
                    action="act_service_conception_view"/>
    </data>
</odoo>
