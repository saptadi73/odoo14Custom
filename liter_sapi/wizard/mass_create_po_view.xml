<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--Setoran Susu-->
        <record id="mass_create_po_view" model="ir.ui.view">
            <field name="name">Mass Create PO</field>
            <field name="model">create.po.wiz</field>
            <field name="arch" type="xml">
                <form string="Create PO">
                    <group>
                    </group>
                    <span class="o_form_label">All selected Setoran. You won't be able to modify them afterwards.</span>
                    <footer>
                        <button string="Create PO" name="mass_create_po" type="object" default_focus="1" class="btn-primary" data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_mass_create_po" model="ir.actions.act_window">
            <field name="name">Create PO</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">create.po.wiz</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="mass_create_po_view"/>
            <field name="context">{}</field>
            <field name="target">new</field>
            <field name="help">This wizard will Create PO all setoran selected</field>
            <field name="binding_model_id" ref="liter_sapi.model_liter_sapi" />
            <field name="binding_view_types">list</field>
        </record>

    </data>
</odoo>