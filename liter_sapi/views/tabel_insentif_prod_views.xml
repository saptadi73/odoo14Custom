<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tabel_insentif_prod_tree" model="ir.ui.view">
            <field name="name">tabel.insentif.prod.tree</field>
            <field name="model">tabel.insentif.prod</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Tabel Insentif Prod">
                    <field name="peternak_id"/>
                    <field name="name"/>
                    <field name="nilai_min"/>
                    <field name="nilai_max"/>
                    <field name="nilai_insen_prod_mitra"/>
                    <field name="is_active"/>
                </tree>
            </field>
        </record>

        <record id="view_tabel_insentif_prod_form" model="ir.ui.view">
            <field name="name">tabel.insentif.prod.form</field>
            <field name="model">tabel.insentif.prod</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Tabel Insentif Prod">
                    <sheet>
                        <group >
                            <field name="peternak_id"/>
                            <field name="name"/>
                            <field name="nilai_min"/>
                            <field name="nilai_max"/>
                            <field name="nilai_insen_prod_mitra"/>
                            <field name="is_active"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_tabel_insentif_prod_search" model="ir.ui.view">
            <field name="name">tabel.insentif.prod.search</field>
            <field name="model">tabel.insentif.prod</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Tabel Insentif Prod">
<!--                    <field name="hijauan"/>-->
                    <newline/>
                    <group expand="0" string="Group By...">
<!--                        <filter string="Tabel Insentif Prod" name="group_by_hijauan_group_name"-->
<!--                                domain="[]" context="{'group_by':'hijauan'}"/>-->
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_tabel_insentif_prod_view">
            <field name="name">Tabel Insentif Prod</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tabel.insentif.prod</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_tabel_insentif_prod_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_tabel_insentif_prod_form">
            <field name="act_window_id" ref="act_tabel_insentif_prod_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_tabel_insentif_prod_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_tabel_insentif_prod_tree">
            <field name="act_window_id" ref="act_tabel_insentif_prod_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_tabel_insentif_prod_tree"/>
        </record>

        <menuitem id="menu_tabel_insentif_prod_details"
                    name="Tabel Insentif Prod"
                    parent="menu_konfig_liter"
                    sequence="50"
                    action="act_tabel_insentif_prod_view"/>
    </data>
</odoo>
