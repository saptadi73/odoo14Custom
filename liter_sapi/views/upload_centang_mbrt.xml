<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_upload_centang_mbrt_tree" model="ir.ui.view">
            <field name="name">upload.centang.mbrt.tree</field>
            <field name="model">upload.centang.mbrt</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Upload Hasil Centang">
                    <field name="periode_id"/>
                    <field name="tps_id"/>
                </tree>
            </field>
        </record>

        <record id="view_upload_centang_mbrt_form" model="ir.ui.view">
            <field name="name">upload.centang.mbrt.form</field>
            <field name="model">upload.centang.mbrt</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Upload Hasil Centang">
                    <header>
                        <button string="Push Hasil Centang" type="object" name="push_hasil_centang"/>
                    </header>
                    <sheet>
                        <group col="4">
                            <field name="periode_id"/>
                            <field name="tps_id"/>
                        </group>
                        <notebook>
                            <page string="List Hasil Centang">
                                <group>
                                    <field name="upload_centang_ids" nolabel="1" options="{'reload_on_button': True}">
                                        <tree edit="true" editable="bottom" create="true" delete="true">
                                            <field name="kode_peternak"/>
                                            <field name="peternak_id"/>
                                            <field name="tgl_setor"/>
                                            <field name="is_mbrt"/>
                                        </tree>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_upload_centang_mbrt_search" model="ir.ui.view">
            <field name="name">upload.centang.mbrt.search</field>
            <field name="model">upload.centang.mbrt</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Upload Hasil Centang">
<!--                    <field name="hijauan"/>-->
                    <newline/>
                    <group expand="0" string="Group By...">
<!--                        <filter string="Upload Hasil Centang" name="group_by_hijauan_group_name"-->
<!--                                domain="[]" context="{'group_by':'hijauan'}"/>-->
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_upload_centang_mbrt_view">
            <field name="name">Upload Hasil Centang</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">upload.centang.mbrt</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_upload_centang_mbrt_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_upload_centang_mbrt_form">
            <field name="act_window_id" ref="act_upload_centang_mbrt_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_upload_centang_mbrt_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_upload_centang_mbrt_tree">
            <field name="act_window_id" ref="act_upload_centang_mbrt_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_upload_centang_mbrt_tree"/>
        </record>

        <menuitem id="menu_upload_centang_mbrt_details"
                    name="Upload Hasil Centang"
                    parent="menu_setoran_susu"
                    sequence="40"
                    action="act_upload_centang_mbrt_view"/>
    </data>
</odoo>