<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_periode_setoran_tree" model="ir.ui.view">
            <field name="name">periode.setoran.tree</field>
            <field name="model">periode.setoran</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Periode">
                    <field name="periode_setoran"/>
                    <field name="periode_setoran_awal"/>
                    <field name="periode_setoran_akhir"/>
                </tree>
            </field>
        </record>

        <record id="view_periode_setoran_form" model="ir.ui.view">
            <field name="name">periode.setoran.form</field>
            <field name="model">periode.setoran</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Periode">
                    <header>
                    </header>
                    <sheet>
                        <group>
                            <field name="periode_setoran"/>
                        </group>
			<group col="4">
			    <field name="periode_setoran_awal"/>
                            <field name="periode_setoran_akhir"/>
			</group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_periode_setoran_search" model="ir.ui.view">
            <field name="name">periode.setoran.search</field>
            <field name="model">periode.setoran</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Periode">
                    <field name="periode_setoran"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Periode" name="group_by_periode_setoran_name"
                                domain="[]" context="{'group_by':'periode_setoran'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_periode_setoran_liter_view">
            <field name="name">Periode Setoran</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">periode.setoran</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_periode_setoran_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_periode_setoran_liter_view_form">
            <field name="act_window_id" ref="act_periode_setoran_liter_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_periode_setoran_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_periode_setoran_liter_view_tree">
            <field name="act_window_id" ref="act_periode_setoran_liter_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_periode_setoran_tree"/>
        </record>

        <menuitem id="menu_periode_setoran_liter"
                    name="Periode Setoran"
                    parent="menu_liter_root"
                    sequence="30"
                    action="act_periode_setoran_liter_view"/>
    </data>
</odoo>
