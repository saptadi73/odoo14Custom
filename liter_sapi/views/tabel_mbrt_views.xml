<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tabel_mbrt_tree" model="ir.ui.view">
            <field name="name">tabel.mbrt.tree</field>
            <field name="model">tabel.mbrt</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Tabel MBRT">
                    <field name="name"/>
                    <field name="is_default"/>
                    <field name="is_mitra"/>
                    <field name="value"/>
                </tree>
            </field>
        </record>

        <record id="view_tabel_mbrt_form" model="ir.ui.view">
            <field name="name">tabel.mbrt.form</field>
            <field name="model">tabel.mbrt</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Tabel MBRT">
                    <sheet>
                        <group string="Tabel Default BJ">
                            <field name="name"/>
                            <field name="is_default"/>
                            <field name="is_mitra"/>
                            <field name="value"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_tabel_mbrt_search" model="ir.ui.view">
            <field name="name">tabel.mbrt.search</field>
            <field name="model">tabel.mbrt</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Tabel MBRT">
<!--                    <field name="hijauan"/>-->
                    <newline/>
                    <group expand="0" string="Group By...">
<!--                        <filter string="Tabel MBRT" name="group_by_hijauan_group_name"-->
<!--                                domain="[]" context="{'group_by':'hijauan'}"/>-->
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_tabel_mbrt_view">
            <field name="name">Tabel MBRT</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tabel.mbrt</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_tabel_mbrt_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_tabel_mbrt_form">
            <field name="act_window_id" ref="act_tabel_mbrt_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_tabel_mbrt_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_tabel_mbrt_tree">
            <field name="act_window_id" ref="act_tabel_mbrt_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_tabel_mbrt_tree"/>
        </record>

        <menuitem id="menu_tabel_mbrt_details"
                    name="Tabel MBRT"
                    parent="menu_konfig_liter"
                    sequence="60"
                    action="act_tabel_mbrt_view"/>
    </data>
</odoo>
