<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tabel_ts_tree" model="ir.ui.view">
            <field name="name">tabel.ts.tree</field>
            <field name="model">tabel.ts</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Tabel TS">
                    <field name="bj_id"/>
                    <field name="fat_id"/>
                    <field name="ts"/>
                </tree>
            </field>
        </record>

        <record id="view_tabel_ts_form" model="ir.ui.view">
            <field name="name">tabel.ts.form</field>
            <field name="model">tabel.ts</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Tabel TS">
                    <sheet>
                        <group string="Tabel TS">
                            <field name="bj_id"/>
                            <field name="fat_id"/>
                            <field name="ts"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_tabel_ts_search" model="ir.ui.view">
            <field name="name">tabel.ts.search</field>
            <field name="model">tabel.ts</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Tabel TS">
<!--                    <field name="hijauan"/>-->
                    <newline/>
                    <group expand="0" string="Group By...">
<!--                        <filter string="Tabel TS" name="group_by_hijauan_group_name"-->
<!--                                domain="[]" context="{'group_by':'hijauan'}"/>-->
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_tabel_ts_view">
            <field name="name">Tabel TS</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tabel.ts</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_tabel_ts_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_tabel_ts_form">
            <field name="act_window_id" ref="act_tabel_ts_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_tabel_ts_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_tabel_ts_tree">
            <field name="act_window_id" ref="act_tabel_ts_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_tabel_ts_tree"/>
        </record>

        <menuitem id="menu_tabel_ts_details"
                    name="Tabel TS"
                    parent="menu_konfig_liter"
                    sequence="80"
                    action="act_tabel_ts_view"/>
    </data>
</odoo>
