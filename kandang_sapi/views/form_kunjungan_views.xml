<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_form_kunjungan_tree" model="ir.ui.view">
            <field name="name">form.kunjungan.tree</field>
            <field name="model">form.kunjungan</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Form Kunjungan">
                    <field name="code"/>
                    <field name="peternak_id"/>
                    <field name="kode_peternak"/>
                    <field name="tanggal_kunjungan"/>
                    <field name="petugas_id"/>
                    <field name="note"/>
                </tree>
            </field>
        </record>

        <record id="view_form_kunjungan_form" model="ir.ui.view">
            <field name="name">form.kunjungan.form</field>
            <field name="model">form.kunjungan</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Form Kunjungan">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="code" readonly="1"/>
                            </h1>
                        </div>
                        <group col="4">
                            <field name="peternak_id"/>
                            <field name="kode_peternak"/>
                            <field name="tanggal_kunjungan"/>
                            <field name="petugas_id"/>
<!--                            <field name="jenis_kunjungan_ids"/>-->
                            <field name="jenis_kunjungan_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="solusi_kunjungan_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="note"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_form_kunjungan_search" model="ir.ui.view">
            <field name="name">form.kunjungan.search</field>
            <field name="model">form.kunjungan</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Form Kunjungan">
                    <field name="kode_peternak"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Kode Peternak" name="group_by_kode_peternak_group_name"
                                domain="[]" context="{'group_by':'kode_peternak'}"/>
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_form_kunjungan_view">
            <field name="name">Form Kunjungan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">form.kunjungan</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_form_kunjungan_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_form_kunjungan_view_form">
            <field name="act_window_id" ref="act_form_kunjungan_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_form_kunjungan_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_form_kunjungan_view_tree">
            <field name="act_window_id" ref="act_form_kunjungan_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_form_kunjungan_tree"/>
        </record>

        <menuitem id="menu_form_kunjungan_details"
                    name="Form Kunjungan"
                    parent="menu_kunjungan_root"
                    sequence="30"
                    action="act_form_kunjungan_view"/>
    </data>
</odoo>
