<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_master_solusi_kunjungan_tree" model="ir.ui.view">
            <field name="name">master.solusi.kunjungan.tree</field>
            <field name="model">master.solusi.kunjungan</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Master Solusi Kunjungan">
                    <field name="solusi_kunjungan"/>
                    <field name="kode"/>
                </tree>
            </field>
        </record>

        <record id="view_master_solusi_kunjungan_form" model="ir.ui.view">
            <field name="name">master.solusi.kunjungan.form</field>
            <field name="model">master.solusi.kunjungan</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Master Solusi Kunjungan">
                    <sheet>
                        <group col="4">
                            <field name="solusi_kunjungan"/>
                            <field name="kode"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_master_solusi_kunjungan_search" model="ir.ui.view">
            <field name="name">master.solusi.kunjungan.search</field>
            <field name="model">master.solusi.kunjungan</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Master Solusi Kunjungan">
                    <field name="solusi_kunjungan"/>
                    <field name="kode"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Master Solusi Kunjungan" name="group_by_solusi_kunjungan_group_name"
                                domain="[]" context="{'group_by':'solusi_kunjungan'}"/>
<!--                        <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>-->
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_master_solusi_kunjungan_view">
            <field name="name">Master Solusi Kunjungan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">master.solusi.kunjungan</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_master_solusi_kunjungan_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_master_solusi_kunjungan_view_form">
            <field name="act_window_id" ref="act_master_solusi_kunjungan_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_master_solusi_kunjungan_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_master_solusi_kunjungan_view_tree">
            <field name="act_window_id" ref="act_master_solusi_kunjungan_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_master_solusi_kunjungan_tree"/>
        </record>

        <menuitem id="menu_master_solusi_kunjungan_details"
                    name="Master Solusi Kunjungan"
                    parent="menu_konfigurasi_root"
                    sequence="40"
                    action="act_master_solusi_kunjungan_view"/>
    </data>
</odoo>
