<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_cip_tree" model="ir.ui.view">
            <field name="name">cip.tree</field>
            <field name="model">cip</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="CIP">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="ref"/>
                    <field name="date"/>
                    <field name="account_analytic_id"/>
                    <field name="eartag_id"/>
                    <field name="sapi_id"/>
                    <field name="company_id"/>
                    <field name="gross_value"/>
                </tree>
            </field>
        </record>

        <record id="view_cip_form" model="ir.ui.view">
            <field name="name">cip.form</field>
            <field name="model">cip</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="CIP">
                    <header>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="category_id"/>
                                <field name="ref"/>
                                <field name="date"/>
                                <field name="account_analytic_id"/>
                                <field name="eartag_id"/>
                                <field name="sapi_id"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                                <field name="gross_value"/>
                            </group>
                        </group>
<!--                        <group string="Setoran">-->
<!--                            <field name="setoran_line_rearing_ids" nolabel="1" options="{'reload_on_button': True}">-->
<!--                                <tree edit="true" editable="bottom" create="true" delete="true">-->
<!--                                    <field name="tgl_setor"/>-->
<!--                                    <field name="sapi_id"/>-->
<!--                                    <field name="eartag_id"/>-->
<!--                                    <field name="tipe_setor"/>-->
<!--                                    <field name="setoran"/>-->
<!--                                    <field name="uom_id"/>-->
<!--                                    <field name="note"/>-->
<!--                                </tree>-->
<!--                            </field>-->
<!--                        </group>-->
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_cip_search" model="ir.ui.view">
            <field name="name">cip.search</field>
            <field name="model">cip</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="CIP">
                    <field name="name"/>
                    <field name="category_id"/>
                    <newline/>
                    <group expand="0" string="Group By...">
                        <filter string="Asset" name="group_by_name"
                                domain="[]" context="{'group_by':'name'}"/>
                        <filter string="Category" name="group_by_category_id"
                                domain="[]" context="{'group_by':'category_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_cip_pivot" model="ir.ui.view">
            <field name="name">liter.pivot</field>
            <field name="model">cip</field>
            <field name="arch" type="xml">
                <pivot>

                </pivot>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cip_view">
            <field name="name">CIP</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cip</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="search_view_id" ref="view_cip_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_cip_view_form">
            <field name="act_window_id" ref="act_cip_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_cip_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_cip_view_tree">
            <field name="act_window_id" ref="act_cip_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_cip_tree"/>
        </record>

        <menuitem id="menu_cip_details"
                    name="CIP"
                    parent="menu_liter_rearing_details"
                    sequence="10"
                    action="act_cip_view"/>
    </data>
</odoo>