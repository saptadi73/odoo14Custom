<openerp>
  <data>

    
     <record id="view_employee_pajak" model="ir.ui.view">
      <field name="name">Employee Inherite Pajak</field>
      <field name="model">hr.employee</field>
      <field name="inherit_id" ref="hr.view_employee_form"/>
      <field name="arch" type="xml">
       	<field name="department_id" position="after"> 
             <field name="divisi_id"/>
        </field>

      </field>
      
    </record>
    
    <record id="view_divisi_form" model="ir.ui.view">
            <field name="name">divisi.view.form</field>
            <field name="model">hr.employee.divisi</field>
            <field name="arch" type="xml">
                <form string="Divisi">
                  <sheet>
                  	<group>
	                  	<group>
					        <field name="name"/>
					    </group>
					    <group>
					    </group>
				    </group>    
                </sheet>
                </form>
            </field>
        </record>
        
       <record id="view_divisi_tree" model="ir.ui.view">
            <field name="name">divisi.view.tree</field>
            <field name="model">hr.employee.divisi</field>
            <field name="arch" type="xml">
                <tree string="Divisi">
				     <field name="name"/> 
                </tree>
            </field>
        </record>
        
        
       <record model="ir.actions.act_window" id="action_divisi">
	    	<field name="name">Divisi</field>
	    	<field name="res_model">hr.employee.divisi</field>
	    	<field name="view_mode">form</field>
	    	<field name="view_mode">tree,form</field>
		</record>

		<menuitem id="menu_divisi"
            name="Divisi"  
            action="action_divisi" 
            parent="hr.menu_human_resources_configuration" 
            sequence="10"/>
    
    
    
     
    
  </data>
</openerp>